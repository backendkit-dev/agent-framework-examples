# ─── Docker ─────────────────────────────────────────────────────────────────────
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_HOST=
DEFAULT_TIMEOUT=30000

# ─── LLM ────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ─── MCP Server ─────────────────────────────────────────────────────────────────
MCP_PORT=3100
MCP_HOST=127.0.0.1

# ─── Kubernetes ─────────────────────────────────────────────────────────────────
KUBECONFIG=
K8S_NAMESPACE=default

# ─── Containerd ─────────────────────────────────────────────────────────────────
CONTAINERD_RUNTIME=nerdctl
CONTAINERD_NAMESPACE=default
