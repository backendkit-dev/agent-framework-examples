{
  "name": "@backendkit-labs/agent",
  "version": "1.0.0",
  "description": "AI coding agent specialized in Node.js and NestJS backend development with BackendKit Labs libraries",
  "main": "dist/index.js",
  "bin": {
    "deepseek-code": "./dist/bin/cli.js",
    "bk-agent": "./dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:bundle": "esbuild bin/cli.ts --bundle --platform=node --format=cjs --outdir=dist/cli-bundle --entry-names=index --asset-names=[name] --loader:.wasm=file --external:fsevents --external:@vscode/ripgrep --target=node20",
    "update-global": "node scripts/update-global.js",
    "dev": "tsx bin/cli.ts",
    "start": "node dist/bin/cli.js",
    "lint": "eslint src/",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "prepare": "husky"
  },
  "keywords": [
    "deepseek",
    "cli",
    "coding-agent",
    "ai",
    "vault",
    "crypto",
    "cryptocurrency"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@backendkit-labs/console-animations": "^0.1.3",
    "@bk/agent-coding": "file:../../agent-framework/packages/coding",
    "@bk/agent-core": "file:../../agent-framework/packages/core",
    "@vscode/ripgrep": "^1.17.1",
    "chalk": "^5.3.0",
    "cli-highlight": "^2.1.11",
    "commander": "^12.0.0",
    "glob": "^10.3.0",
    "openai": "^4.40.0",
    "tiktoken": "^1.0.15",
    "yaml": "^2.4.0"
  },
  "lint-staged": {
    "*.ts": [
      "node scripts/check-utf8.js",
      "npx tsc --noEmit --pretty"
    ]
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "esbuild": "^0.24.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
