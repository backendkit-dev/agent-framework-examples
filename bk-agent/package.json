{
  "name": "@bk/example-bk-agent",
  "version": "0.1.0",
  "private": true,
  "description": "bk-agent CLI — interactive + headless (JSON-Lines) mode powered by @bk/agent-coding",
  "main": "dist/index.js",
  "bin": {
    "bk-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
